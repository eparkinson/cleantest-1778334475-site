---
import Base from '../layouts/Base.astro';
import '../styles/global.css';
---

<Base>
  <!--
    ============================================================
    NAVIGATION
    ============================================================
  -->
  <header class="fixed inset-x-0 top-0 z-50 border-b border-gray-100 bg-white/90 backdrop-blur-sm">
    <nav class="mx-auto flex max-w-7xl items-center justify-between px-6 py-4">
      <!-- PLACEHOLDER: Replace text mark with logo SVG or brand wordmark -->
      <a href="/" class="text-xl font-bold tracking-tight text-gray-900">
        CleanTest
      </a>

      <ul class="hidden items-center gap-8 text-sm font-medium text-gray-600 md:flex">
        <li><a href="#features" class="transition-colors hover:text-gray-900">Features</a></li>
        <li><a href="#about" class="transition-colors hover:text-gray-900">About</a></li>
        <!-- PLACEHOLDER: Add more nav items as the site grows -->
      </ul>

      <!-- PLACEHOLDER: Update CTA label + href (e.g. sign-up page, Calendly, waitlist form) -->
      <a
        href="#cta"
        class="rounded-lg bg-gray-900 px-4 py-2 text-sm font-semibold text-white transition-colors hover:bg-gray-700"
      >
        Get started
      </a>
    </nav>
  </header>

  <main>
    <!--
      ============================================================
      HERO SECTION
      ============================================================
    -->
    <section class="flex min-h-screen items-center justify-center bg-white px-6 pt-20">
      <div class="mx-auto max-w-4xl text-center">
        <!-- PLACEHOLDER: Pre-headline badge / category pill -->
        <span class="mb-6 inline-block rounded-full border border-gray-200 bg-gray-50 px-4 py-1.5 text-xs font-semibold uppercase tracking-widest text-gray-500">
          [PLACEHOLDER: Category or launch badge, e.g. "Now in beta"]
        </span>

        <!-- PLACEHOLDER: Primary headline — 6–10 words, value-forward, no jargon -->
        <h1 class="mt-4 text-5xl font-extrabold leading-tight tracking-tight text-gray-900 md:text-7xl">
          [PLACEHOLDER: Your big,<br class="hidden md:block" /> bold headline here]
        </h1>

        <!-- PLACEHOLDER: Supporting subheadline — 1–2 sentences, expand on the h1 -->
        <p class="mt-6 text-xl leading-relaxed text-gray-500 md:text-2xl">
          [PLACEHOLDER: One or two sentences explaining what CleanTest does and why it matters to your audience.]
        </p>

        <!-- CTAs -->
        <div class="mt-10 flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
          <!-- PLACEHOLDER: Primary CTA — update href to sign-up / waitlist / demo booking -->
          <a
            href="#cta"
            class="w-full rounded-xl bg-gray-900 px-8 py-4 text-base font-semibold text-white shadow-sm transition-colors hover:bg-gray-700 sm:w-auto"
          >
            [PLACEHOLDER: Primary CTA label]
          </a>
          <!-- PLACEHOLDER: Secondary CTA — update href and label -->
          <a
            href="#features"
            class="w-full rounded-xl border border-gray-200 bg-white px-8 py-4 text-base font-semibold text-gray-700 transition-colors hover:bg-gray-50 sm:w-auto"
          >
            [PLACEHOLDER: Secondary CTA label]
          </a>
        </div>

        <!-- PLACEHOLDER: Social proof / trust nudge below CTAs -->
        <p class="mt-8 text-sm text-gray-400">
          [PLACEHOLDER: Trust signal — e.g. "Trusted by 500+ teams" · "No credit card required" · "Free 14-day trial"]
        </p>
      </div>
    </section>

    <!--
      ============================================================
      FEATURES / BENEFITS SECTION
      ============================================================
    -->
    <section id="features" class="bg-gray-50 px-6 py-24">
      <div class="mx-auto max-w-7xl">
        <!-- Section header -->
        <div class="text-center">
          <!-- PLACEHOLDER: Section eyebrow label -->
          <span class="text-sm font-semibold uppercase tracking-widest text-gray-400">
            [PLACEHOLDER: Section label, e.g. "Features" or "Why CleanTest"]
          </span>
          <!-- PLACEHOLDER: Features headline -->
          <h2 class="mt-3 text-4xl font-bold tracking-tight text-gray-900">
            [PLACEHOLDER: What makes CleanTest different]
          </h2>
          <!-- PLACEHOLDER: Features sub-copy -->
          <p class="mt-4 text-lg text-gray-500">
            [PLACEHOLDER: 1–2 sentences summarising the key benefits.]
          </p>
        </div>

        <!-- Feature cards -->
        <div class="mt-16 grid gap-8 md:grid-cols-3">

          <!-- Feature 1 -->
          <div class="rounded-2xl border border-gray-100 bg-white p-8 shadow-sm">
            <!-- PLACEHOLDER: Replace icon with a themed SVG from your icon library -->
            <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-gray-100 text-gray-400">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0z" />
              </svg>
            </div>
            <!-- PLACEHOLDER: Feature 1 title -->
            <h3 class="text-lg font-semibold text-gray-900">[PLACEHOLDER: Feature 1 title]</h3>
            <!-- PLACEHOLDER: Feature 1 description -->
            <p class="mt-2 text-gray-500">
              [PLACEHOLDER: 1–2 sentences describing this feature and the user benefit.]
            </p>
          </div>

          <!-- Feature 2 -->
          <div class="rounded-2xl border border-gray-100 bg-white p-8 shadow-sm">
            <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-gray-100 text-gray-400">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5 14.25 2.25 12 10.5h8.25L9.75 21.75 12 13.5H3.75z" />
              </svg>
            </div>
            <h3 class="text-lg font-semibold text-gray-900">[PLACEHOLDER: Feature 2 title]</h3>
            <p class="mt-2 text-gray-500">
              [PLACEHOLDER: 1–2 sentences describing this feature and the user benefit.]
            </p>
          </div>

          <!-- Feature 3 -->
          <div class="rounded-2xl border border-gray-100 bg-white p-8 shadow-sm">
            <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-gray-100 text-gray-400">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 0 0 3.741-.479 3 3 0 0 0-4.682-2.72m.94 3.198.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0 1 12 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 0 1 6 18.719m12 0a5.971 5.971 0 0 0-.941-3.197m0 0A5.995 5.995 0 0 0 12 12.75a5.995 5.995 0 0 0-5.058 2.772m0 0a3 3 0 0 0-4.681 2.72 8.986 8.986 0 0 0 3.74.477m.94-3.197a5.971 5.971 0 0 0-.94 3.197M15 6.75a3 3 0 1 1-6 0 3 3 0 0 1 6 0zm6 3a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0zm-13.5 0a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0z" />
              </svg>
            </div>
            <h3 class="text-lg font-semibold text-gray-900">[PLACEHOLDER: Feature 3 title]</h3>
            <p class="mt-2 text-gray-500">
              [PLACEHOLDER: 1–2 sentences describing this feature and the user benefit.]
            </p>
          </div>

        </div>
      </div>
    </section>

    <!--
      ============================================================
      CTA SECTION
      ============================================================
    -->
    <section id="cta" class="bg-gray-900 px-6 py-24">
      <div class="mx-auto max-w-3xl text-center">
        <!-- PLACEHOLDER: CTA headline -->
        <h2 class="text-4xl font-bold tracking-tight text-white">
          [PLACEHOLDER: Ready to get started with CleanTest?]
        </h2>
        <!-- PLACEHOLDER: CTA supporting copy -->
        <p class="mt-4 text-lg text-gray-300">
          [PLACEHOLDER: One friction-reducing sentence — e.g. "No setup required. Free 14-day trial."]
        </p>
        <div class="mt-10 flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
          <!-- PLACEHOLDER: Update href — sign-up URL, Calendly, waitlist, or contact form -->
          <a
            href="mailto:hello@cleantest.example.com"
            class="w-full rounded-xl bg-white px-8 py-4 text-base font-semibold text-gray-900 transition-colors hover:bg-gray-100 sm:w-auto"
          >
            [PLACEHOLDER: CTA button label, e.g. "Start free trial" or "Book a demo"]
          </a>
        </div>
        <!-- PLACEHOLDER: Add embedded waitlist / email-capture form here if needed -->
      </div>
    </section>
  </main>

  <!--
    ============================================================
    FOOTER
    ============================================================
  -->
  <footer class="border-t border-gray-100 bg-white px-6 py-12">
    <div class="mx-auto max-w-7xl">
      <div class="flex flex-col items-start justify-between gap-8 md:flex-row">
        <!-- Brand column -->
        <div class="max-w-xs">
          <!-- PLACEHOLDER: Replace with logo -->
          <span class="text-xl font-bold text-gray-900">CleanTest</span>
          <!-- PLACEHOLDER: Short footer tagline -->
          <p class="mt-2 text-sm text-gray-400">[PLACEHOLDER: Short footer tagline — 1 line max.]</p>
        </div>

        <!-- Nav columns -->
        <div class="flex flex-wrap gap-12 text-sm">
          <div>
            <!-- PLACEHOLDER: Footer column heading -->
            <h4 class="font-semibold text-gray-900">[PLACEHOLDER: Column heading]</h4>
            <ul class="mt-3 space-y-2 text-gray-500">
              <!-- PLACEHOLDER: Add real links once pages exist -->
              <li><a href="#features" class="transition-colors hover:text-gray-900">Features</a></li>
              <li><a href="#" class="transition-colors hover:text-gray-900">[PLACEHOLDER: Link]</a></li>
            </ul>
          </div>
          <div>
            <h4 class="font-semibold text-gray-900">[PLACEHOLDER: Column heading]</h4>
            <ul class="mt-3 space-y-2 text-gray-500">
              <!-- PLACEHOLDER: Add Privacy Policy, Terms, etc. when ready -->
              <li><a href="#" class="transition-colors hover:text-gray-900">[PLACEHOLDER: Privacy Policy]</a></li>
              <li><a href="#" class="transition-colors hover:text-gray-900">[PLACEHOLDER: Terms of Service]</a></li>
            </ul>
          </div>
        </div>
      </div>

      <!-- Bottom bar -->
      <div class="mt-10 border-t border-gray-100 pt-6 text-center text-xs text-gray-400">
        <!-- PLACEHOLDER: Update year and legal entity name -->
        &copy; 2025 CleanTest. All rights reserved.
        <!-- PLACEHOLDER: Add social links once accounts exist -->
      </div>
    </div>
  </footer>
</Base>
